{
  "manifest_version": 3,
  "name": "URnetwork",
  "version": "0.1.0",
  "default_locale": "en",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    },
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "scripts": [
      "service-worker-loader.js"
    ],
    "type": "module"
  },
  "permissions": [
    "proxy",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.bringyour.com/*",
    "https://api-v4.bringyour.com/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "wasm/sdk.wasm",
        "wasm/wasm_exec.js"
      ]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://ur.io/*",
      "https://app.ur.network/*"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "urnetwork@bringyour.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
